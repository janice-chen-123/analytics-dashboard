# Copy this file to .env and fill in your actual values.
# NEVER commit .env to GitHub.

# OpenAI API Key
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model name (change this without touching code if the model changes)
# Recommended: gpt-4o-mini (cost-effective) or gpt-4o (higher quality)
OPENAI_MODEL=gpt-4o-mini

# Optional: Max tokens for AI response (default used in code if not set)
OPENAI_MAX_TOKENS=1500
